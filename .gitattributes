# Normalize line endings so editors / sync tools stop rewriting every file.
# Text files are stored with LF in the repo and checked out with LF.
* text=auto eol=lf

# Treat binary assets as binary (never line-ending normalized).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.pdf  binary
*.zip  binary
