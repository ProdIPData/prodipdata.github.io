---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getItems, formatInteger, formatCompact, formatAsnTypeLabel, sortByRank,
  currentReleaseMonth, loadData, loadYearData, releasesData,
} from '../lib/format.js';

const month = currentReleaseMonth;
const overview = loadData('overview-global') || {};
const topAsns = loadData('top-asns-global') || {};
const newAsns = loadYearData('new-added-asns') || [];
const releases = releasesData;
const statCountries = formatInteger(overview.totalCountriesRepresented);
const statAsns = formatInteger(overview.totalAsns);

const releaseItems = Array.isArray(releases.items) ? releases.items : [];
const metrics = [
  { label: 'Represented countries', value: formatInteger(overview.totalCountriesRepresented), text: 'Countries represented in the current published release.' },
  { label: 'Observed ASNs', value: formatInteger(overview.totalAsns), text: 'Distinct autonomous systems represented in the current global footprint.' },
  { label: 'Active ASNs', value: formatInteger(overview.activeAsns), text: 'Operationally active autonomous systems represented in the current release.' },
  { label: 'Published IPv4 footprint', value: formatCompact(overview.totalIpv4), text: 'Estimated IPv4 footprint represented in the current release.' },
];
const biggest = sortByRank(topAsns.biggestASNs).slice(0, 5);
const topCountries = sortByRank(topAsns.topByCountry).slice(0, 5);
const newest = getItems(newAsns).slice(0, 5);

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ProdIPData',
  alternateName: 'ProdIPData',
  url: 'https://prodipdata.com/',
  description:
    'Free IP geolocation database downloads with monthly CSV, Parquet, and MMDB releases, ASN coverage data, and IPv4 geolocation insights from ProdIPData.',
};
---
<BaseLayout
  title="Free IP Geolocation Database Downloads, ASN and Coverage Maps | ProdIPData"
  description="Download free IP geolocation data from ProdIPData, including monthly CSV, Parquet, and MMDB releases, ASN intelligence, and country coverage summaries."
  canonicalPath="/"
  page="home"
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(website)} />

  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-panel glass">
          <div class="eyebrow">IP geolocation data and network intelligence by ProdIPData</div>
          <h1>IP geolocation intelligence for coverage, routing, analytics, and operational insight.</h1>
          <p>
            Explore country, ASN, and regional registry views backed by the latest ProdIPData release. ProdIPData helps teams
            understand IP location, network ownership, and published footprint through downloadable files and browser-based views
            built for practical use.
          </p>
          <div class="actions">
            <a class="btn btn-primary" href="coverage.html">Explore Coverage</a>
            <a class="btn btn-secondary" href="downloads.html">Review Downloads</a>
          </div>
          <div class="data-note">All public website content, monthly release files, and technical reference catalogs on ProdIPData are provided totally free. Unless otherwise stated, published datasets and metadata are available under <a href="licensing.html">CC BY 4.0</a>.</div>
          <div class="stats-grid">
            <div class="stat-card">
              <strong data-home-stat="countries">{statCountries}</strong>
              <span class="muted">Countries represented in the current ProdIPData release.</span>
            </div>
            <div class="stat-card">
              <strong data-home-stat="asns">{statAsns}</strong>
              <span class="muted">Distinct ASNs represented in the current global footprint.</span>
            </div>
            <div class="stat-card">
              <strong data-home-stat="release" data-current-release>{month}</strong>
              <span class="muted">Current published release month used across the website.</span>
            </div>
          </div>
        </div>
        <aside class="sidebar-panel glass">
          <h3>Current release availability</h3>
          <p class="card-text">
            ProdIPData publishes monthly datasets and downloadable files through a lightweight static website so teams can review the
            latest release quickly and integrate it into internal systems, applications, and workflows.
          </p>
          <div class="download-list" data-release-target>
            {releaseItems.map((item) => (
              <div class="download-item">
                <div>
                  <strong>{item.title}</strong>
                  <small>{item.description}</small>
                </div>
                <span class={`badge ${item.statusClass || 'info'}`}>{item.status || 'Info'}</span>
              </div>
            ))}
          </div>
          <div class="data-note">
            All public website content and downloadable files are provided totally free. Unless otherwise stated, published datasets and metadata are available under <a href="licensing.html">CC BY 4.0</a>. Use <a href="releases/index.html">the release archive</a> to navigate by month, use Coverage to explore countries and registries, or use Downloads to access CSV, Parquet, and MMDB files for local analysis.
          </div>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <div><h2>How IP geolocation works</h2></div>
          <p>
            IP geolocation links IP addresses to approximate geographic and network context. ProdIPData presents this information through
            country, ASN, and registry views that help users interpret coverage at a practical level.
          </p>
        </div>
        <div class="grid-3">
          <article class="section-card glass">
            <h3>IP address lookup</h3>
            <p class="card-text">An IP address can be associated with an approximate country, network, or published footprint so teams can understand where activity appears to originate and how it is represented in the release.</p>
          </article>
          <article class="section-card glass">
            <h3>Network and routing context</h3>
            <p class="card-text">IP geolocation interpretation is strengthened by ASN, registry, and broader network context. ProdIPData complements location-oriented views with operator, footprint, and concentration signals.</p>
          </article>
          <article class="section-card glass">
            <h3>Accuracy depends on granularity</h3>
            <p class="card-text">Country-level interpretation is typically stronger than assumptions about exact city placement or precise coordinates. IP geolocation works best when it is read as high-value context rather than perfect physical location.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <div><h2>Why teams use ProdIPData</h2></div>
          <p>
            ProdIPData helps technical and business teams work from structured IP geolocation files, browser-based views, and release-ready
            summaries that fit operational and analytical workflows.
          </p>
        </div>
        <div class="grid-3">
          <article class="section-card glass">
            <h3>Personalize local experiences</h3>
            <p class="card-text">Use country and network context to tailor content, reporting, and audience segmentation to the geographic footprint that matters to your organization.</p>
          </article>
          <article class="section-card glass">
            <h3>Analyze traffic and ownership</h3>
            <p class="card-text">Review country coverage, published prefixes, ASN concentration, and registry structure to understand how network presence is distributed across the internet footprint.</p>
          </article>
          <article class="section-card glass">
            <h3>Support operations and investigations</h3>
            <p class="card-text">Use downloadable files and web views to support routing reviews, internal enrichment workflows, exception analysis, and geolocation issue research.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <div><h2>Intent-led data guides</h2></div>
          <p>
            Start with the page that matches the question you already have, whether that question is about IP geolocation data,
            downloads, file formats, or country-level ASN structure.
          </p>
        </div>
        <div class="download-grid">
          <article class="section-card glass">
            <h3><a href="ip-geolocation-database.html">IP geolocation database downloads</a></h3>
            <p class="card-text">Use this entry page when the main need is downloadable IP geolocation files and local hosting workflows.</p>
          </article>
          <article class="section-card glass">
            <h3><a href="ip-geolocation-data.html">IP geolocation data</a></h3>
            <p class="card-text">Use this guide to understand what IP geolocation data means and how country and network signals should be interpreted.</p>
          </article>
          <article class="section-card glass">
            <h3><a href="asn-data-by-country.html">ASN data by country</a></h3>
            <p class="card-text">Use this page for country-level operator structure, lead ASN share, and concentration questions.</p>
          </article>
          <article class="section-card glass">
            <h3><a href="ip-geolocation-csv-download.html">IP geolocation CSV downloads</a></h3>
            <p class="card-text">Use this guide when the target workflow is spreadsheets, SQL imports, or simple operational ingestion.</p>
          </article>
          <article class="section-card glass">
            <h3><a href="ip-geolocation-parquet-download.html">IP geolocation Parquet downloads</a></h3>
            <p class="card-text">Use this guide when the target workflow is analytics, Python, notebooks, or batch processing.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <div><h2>Release archive and current month</h2></div>
          <p>
            ProdIPData is moving toward a release-oriented discovery path so users can move from global summaries to a month-specific release page and then into the CSV, Parquet, or MMDB package indexes that support local reuse.
          </p>
        </div>
        <div class="grid-3">
          <article class="section-card glass">
            <h3><a href="releases/index.html">IP geolocation monthly release archive</a></h3>
            <p class="card-text">Browse the release archive when the goal is to understand what is available by month and which publication assets belong to each release.</p>
          </article>
          <article class="section-card glass">
            <h3><a href={`releases/${month}/index.html`}>Release {month} overview</a></h3>
            <p class="card-text">Open the current release page for scope, package paths, methodology links, checksums guidance, and release-level notes.</p>
          </article>
          <article class="section-card glass">
            <h3><a href="downloads.html">IP geolocation download indexes</a></h3>
            <p class="card-text">Go directly to the CSV, Parquet, and MMDB package indexes when the next step is download, local hosting, or workflow integration.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <div><h2>Current release metrics</h2></div>
          <p>
            These headline metrics summarize the latest published IP geolocation footprint, including country coverage, observed ASNs,
            active networks, and estimated IPv4 scale.
          </p>
        </div>
        <div class="metric-grid" data-metrics-target>
          {metrics.map((m) => (
            <div class="metric-card glass">
              <div class="muted">{m.label}</div>
              <div class="metric-value">{m.value}</div>
              <div class="card-text">{m.text}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container grid-2">
        <div class="split-panel glass">
          <h3>Largest ASN footprints</h3>
          <p class="card-text">
            Leading networks in the current release by published /24 footprint, useful for quickly identifying the largest visible
            operators in the dataset.
          </p>
          <div class="download-list" data-home-biggest-target>
            {biggest.map((item) => (
              <div class="list-row">
                <div>
                  <strong>{item.asnName || `AS${item.asnId}`}</strong>
                  <small>AS{formatInteger(item.asnId)} · {item.countryName || item.countryIso || 'Unknown'} · {formatAsnTypeLabel(item.asnType || 'unknown')}</small>
                </div>
                <div class="list-metric">
                  <strong>{formatInteger(item.prefixCount)}</strong>
                  <small>/24 prefixes</small>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="split-panel glass">
          <h3>Largest country footprints</h3>
          <p class="card-text">
            Countries with the largest published footprint in the current release, combining scale, coverage, and overall IPv4 presence.
          </p>
          <div class="download-list" data-home-country-target>
            {topCountries.map((item) => (
              <div class="list-row">
                <div>
                  <strong>{item.countryName || item.countryIso || 'Unknown'}</strong>
                  <small>{item.countryIso || 'N/A'} · {formatInteger(item.asnCount)} ASNs</small>
                </div>
                <div class="list-metric">
                  <strong>{formatCompact(item.ipv4Count)}</strong>
                  <small>IPv4 est.</small>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <div><h2>New ASN additions in the current year</h2></div>
          <p>
            This section highlights recently added ASNs from the current year so visitors can track new network entries and the
            evolving shape of the published internet footprint.
          </p>
        </div>
        <div class="split-panel glass">
          <div class="download-list" data-home-new-asns-target>
            {newest.map((item) => (
              <div class="list-row">
                <div>
                  <strong>{item.autonomousSystem || `AS${item.id}`}</strong>
                  <small>{item.name || 'Unnamed ASN'} · {item.country || 'Unknown'} · {item.rir || 'unknown'}</small>
                </div>
                <div class="list-metric">
                  <strong>{item.created || 'N/A'}</strong>
                  <small>{formatAsnTypeLabel(item.type || 'unknown')}</small>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section" data-wave4-block="discovery-links">
      <div class="container">
        <div class="split-panel glass content">
          <h2>Explore deeper release and entity pages</h2>
          <p>
            The monthly release archive connects the current dataset to focused country, registry, and ASN pages. Use the <a href="releases/index.html">monthly release archive</a> for time-based navigation, open <a href="country/index.html">country profiles</a> for country-level footprint context, review <a href="rir/index.html">RIR pages</a> for registry-level coverage, and open <a href="asn/index.html">ASN profiles</a> for visible network entities in the current release. For package access, continue through <a href="downloads.html">IP geolocation CSV, Parquet, and MMDB downloads</a>, and for source quality and caveats, review <a href="methodology.html">IP geolocation methodology and validation</a>.
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
