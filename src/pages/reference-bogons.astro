---
import BaseLayout from '../layouts/BaseLayout.astro';
import raw from '../../reference-bogons.html?raw';
import { wrapLegacy } from '../lib/wrap.js';
const { title, description, ogTitle, headSchemas, slotHtml } = wrapLegacy(raw);
---
<BaseLayout title={title} description={description} ogTitle={ogTitle} canonicalPath="/reference-bogons.html" page="reference-bogons" navPage="downloads">
  <Fragment slot="head" set:html={headSchemas} />
  <Fragment set:html={slotHtml} />
</BaseLayout>
