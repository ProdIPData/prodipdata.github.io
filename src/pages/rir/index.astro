---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  numericValue, formatInteger, formatCompact, formatRirName,
  sortRirProfiles, currentReleaseMonth, loadData,
} from '../../lib/format.js';

const month = currentReleaseMonth;
const items = sortRirProfiles(loadData('rir-profiles') || []);

const totalCountries = items.reduce((s, i) => s + numericValue(i.countryCount), 0);
const totalAsns = items.reduce((s, i) => s + numericValue(i.asnCount), 0);
const totalPrefixes = items.reduce((s, i) => s + numericValue(i.prefixCount), 0);

const metrics = [
  { label: 'Published RIR profiles', value: formatInteger(items.length), text: 'Registry profiles currently exposed through the monthly release.' },
  { label: 'Countries covered', value: formatInteger(totalCountries), text: 'Country assignments represented across the current published registry profiles.' },
  { label: 'Observed ASNs', value: formatInteger(totalAsns), text: 'Registry-level ASN footprint represented in the current release.' },
  { label: 'Published /24 footprint', value: formatCompact(totalPrefixes), text: 'Published prefix footprint represented across the visible registry profiles.' },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': 'https://geoiplocations.com/rir/#breadcrumb',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://geoiplocations.com/' },
    { '@type': 'ListItem', position: 2, name: 'Coverage', item: 'https://geoiplocations.com/coverage.html' },
    { '@type': 'ListItem', position: 3, name: 'RIR', item: 'https://geoiplocations.com/rir/' },
  ],
};
---
<BaseLayout
  title="RIR Coverage Profiles by Release | ProdIPData"
  description="Browse regional internet registry landing pages from ProdIPData with country coverage, prefix scale, ASN context, and release-aware navigation."
  ogTitle="RIR Coverage Profiles by Release"
  canonicalPath="/rir/"
  page="rir"
  navPage="coverage"
  assetRoot="../"
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />

  <main>
    <section class="page-hero">
      <div class="container">
        <div class="page-panel glass">
          <div class="eyebrow page-kicker">RIR pages</div>
          <h1>Regional registry landing pages</h1>
          <p class="page-intro">These pages give each major registry a dedicated view within the current release, including coverage, ASN mix, and published IPv4 scale.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="split-panel glass content">
          <h2>Registry landing pages for release {month}</h2>
          <p>
            These registry pages let visitors review the current release by RIR, including country mix, published prefix scale, and release context without relying on the map alone.
          </p>
          <p class="card-text">
            Each registry profile below summarizes country count, ASN scale, published prefix footprint, and the ASN-type mix that shapes the current monthly release.
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container metric-grid" data-rir-metrics-target>
        {metrics.map((m) => (
          <div class="metric-card glass">
            <div class="muted">{m.label}</div>
            <div class="metric-value">{m.value}</div>
            <div class="card-text">{m.text}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="split-panel glass content">
          <h2>Published RIR profiles in release {month}</h2>
          <div data-rir-list-target>
            <div class="grid-2">
              {items.map((item) => (
                <article class="section-card glass">
                  <h3>{formatRirName(item.rir || 'unknown')}</h3>
                  <p class="card-text">{item.website || 'Website unavailable'} · {item.whoisServer || 'Whois unavailable'}</p>
                  <div class="list-row">
                    <div>
                      <strong>Countries covered</strong>
                      <small>Country profiles represented in the current release</small>
                    </div>
                    <div class="list-metric">
                      <strong>{formatInteger(item.countryCount)}</strong>
                      <small>countries</small>
                    </div>
                  </div>
                  <div class="list-row">
                    <div>
                      <strong>Observed ASNs</strong>
                      <small>Registry-level ASN footprint in the current release</small>
                    </div>
                    <div class="list-metric">
                      <strong>{formatInteger(item.asnCount)}</strong>
                      <small>ASNs</small>
                    </div>
                  </div>
                  <div class="list-row">
                    <div>
                      <strong>Published footprint</strong>
                      <small>Prefix and IPv4 scale for the registry profile</small>
                    </div>
                    <div class="list-metric">
                      <strong>{formatInteger(item.prefixCount)}</strong>
                      <small>{formatCompact(item.ipv4Count)} IPv4</small>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
