---
import BaseLayout from '../layouts/BaseLayout.astro';

const collection = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ProdIPData News',
  description: 'News, release notes, feature updates, and product announcements from ProdIPData by ProdIPData.',
  url: 'https://prodipdata.com/news.html',
  publisher: { '@type': 'Organization', name: 'ProdIPData', url: 'https://prodipdata.com/' },
};
---
<BaseLayout
  title="News | ProdIPData"
  description="News, release notes, feature updates, and product announcements from ProdIPData by ProdIPData."
  ogTitle="ProdIPData News"
  canonicalPath="/news.html"
  page="news"
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(collection)} />

  <main>
    <section class="hero slim">
      <div class="container">
        <div class="eyebrow">Product updates</div>
        <h1>News</h1>
        <p class="hero-copy">
          Release announcements, new dataset formats, catalog improvements, and important updates from ProdIPData.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-header">
          <div>
            <span class="eyebrow">Latest updates</span>
            <h2>Release and feature news</h2>
          </div>
          <p>Follow changes to monthly releases, download formats, data products, and publication workflows.</p>
        </div>

        <div class="card-grid" id="news-list">
          <article class="feature-card">
            <span class="badge">Loading</span>
            <h3>Loading news items...</h3>
            <p>Fetching the latest ProdIPData updates.</p>
          </article>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (async function renderNews() {
      const target = document.getElementById('news-list');
      if (!target) return;

      function escapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, function (ch) {
          return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[ch];
        });
      }

      function formatDate(value) {
        const d = new Date(value + 'T00:00:00Z');
        if (Number.isNaN(d.getTime())) return value || '';
        return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
      }

      try {
        const response = await fetch('assets/data/news.json', { cache: 'no-store' });
        if (!response.ok) throw new Error('Unable to load news.json');
        const items = await response.json();

        if (!Array.isArray(items) || items.length === 0) {
          target.innerHTML = '<article class="feature-card"><span class="badge">No updates</span><h3>No news items published yet</h3><p>News items will appear here when published.</p></article>';
          return;
        }

        target.innerHTML = items.map(function (item) {
          return `
            <article class="feature-card">
              <span class="badge">${escapeHtml(item.category || 'Update')}</span>
              <p class="muted">${escapeHtml(formatDate(item.date))}</p>
              <h3>${escapeHtml(item.title)}</h3>
              <p>${escapeHtml(item.summary)}</p>
            </article>
          `;
        }).join('');
      } catch (err) {
        target.innerHTML = '<article class="feature-card"><span class="badge">Unavailable</span><h3>News feed unavailable</h3><p>The news feed could not be loaded. Please try again later.</p></article>';
      }
    })();
  </script>
</BaseLayout>
